            ],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stellar_wallet\": \"GABC123TIDAKVALID\",\n  \"display_name\": \"Test\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Register Duplikat → 409",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stellar_wallet\": \"GCEZWKCA5VLDNRLN3RPRJMRZOX3Z6G5CHCGM8BKEV4SQWNWQRMWBFBY\",\n  \"display_name\": \"Coba Duplikat\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Route Tidak Ada → 404",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/tidakada",
              "host": ["{{base_url}}"],
