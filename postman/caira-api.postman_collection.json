              "host": ["{{base_url}}"],
              "path": ["api", "invoices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_name\": \"Test\",\n  \"client_email\": \"test@test.com\",\n  \"amount_xlm\": 10\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Email Tidak Valid → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/invoices",
              "host": ["{{base_url}}"],
              "path": ["api", "invoices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_name\": \"Test\",\n  \"client_email\": \"bukan-format-email\",\n  \"amount_xlm\": 10\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Amount Negatif → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/invoices",
              "host": ["{{base_url}}"],
              "path": ["api", "invoices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_name\": \"Test\",\n  \"client_email\": \"test@test.com\",\n  \"amount_xlm\": -5\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Wallet Tidak Valid → 400",
          "request": {
